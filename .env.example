# Server
PORT=2091
NODE_ENV=development

# Local development only. Production refuses to start when this is true.
AUTH_DISABLED=true

# Production OAuth resource-server settings.
MCP_PUBLIC_URL=https://your-mcp-host.example.com
AUTH_ISSUER=https://your-tenant.us.auth0.com/
AUTH_AUDIENCE=https://your-mcp-host.example.com
# Optional; defaults to AUTH_ISSUER + ".well-known/jwks.json".
AUTH_JWKS_URI=

# Land Portal API v2. Put the real key only in your host's secret manager.
LAND_PORTAL_BASE_URL=https://api.landportal.com
LAND_PORTAL_API_KEY=
